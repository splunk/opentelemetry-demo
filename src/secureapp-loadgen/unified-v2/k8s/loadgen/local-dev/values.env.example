# Copy to values.env before deploy.
# deploy.sh applies defaults for all variables not listed here.

# --- Required ---
INGEST_TOKEN=

# --- Splunk identity ---
REALM=us1
DEPLOY_ENV=dev-secureapp-unified

# --- Service names ---
JAVA_SERVICE_NAME=java-ad
PYTHON_SERVICE_NAME=python-ad
NODE_SERVICE_NAME=node-ad

# --- Loadgen ---
# loop: Java in-container loadgen; Python/Node k8s loops when attack flags are true
# once: one-shot k8s jobs per enabled language
# off:  no attack traffic
DATAGEN_MODE=loop

# Per-language attack datagen (disabled until Splunk attack feature ships)
PYTHON_ATTACK_DATAGEN_ENABLED=false
NODE_ATTACK_DATAGEN_ENABLED=false

# --- Cluster ---
K3D_CLUSTER=secapp-default
